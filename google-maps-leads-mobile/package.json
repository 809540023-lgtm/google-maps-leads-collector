{
  "name": "google-maps-leads-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "build:android:apk": "npx eas-cli@latest build --platform android --profile preview",
    "build:ios:preview": "npx eas-cli@latest build --platform ios --profile preview",
    "build:ios:simulator": "npx eas-cli@latest build --platform ios --profile simulator",
    "submit:android": "npx eas-cli@latest submit --platform android",
    "submit:ios": "npx eas-cli@latest submit --platform ios",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "^56.0.12",
    "expo-status-bar": "^56.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-native": "^0.86.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "typescript": "^6.0.3"
  }
}
